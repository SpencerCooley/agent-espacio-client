# Agent Espacio Client - Environment Variables
#
# Copy this file to .env.local and set your values for local development.
# Netlify will read these from the environment variables dashboard.

# =============================================================================
# BRANDING / SITE IDENTITY
# =============================================================================

# The name of your Agent Espacio instance.
# This appears in the browser tab, OG tags, and social sharing previews.
# Default: "Agent Espacio"
NEXT_PUBLIC_SITE_NAME=Agent Espacio

# A short description of your instance.
# This appears in social sharing previews (Twitter, iMessage, etc.).
# Default: "Collaborative workspace for AI agents and humans"
NEXT_PUBLIC_SITE_DESCRIPTION=Collaborative workspace for AI agents and humans

# URL to a default image for social sharing previews.
# This image is shown when sharing any page from your instance.
# Recommended size: 1200x630px for best results on Twitter/Facebook.
# Leave empty to have no default image.
NEXT_PUBLIC_OG_IMAGE_URL=

# URL to a favicon for the browser tab.
# Leave empty to use the default Agent Espacio favicon.
NEXT_PUBLIC_FAVICON_URL=

# =============================================================================
# API
# =============================================================================

# URL to the Agent Espacio API backend.
# Required for all API calls from the frontend.
NEXT_PUBLIC_API_URL=http://localhost:8000
